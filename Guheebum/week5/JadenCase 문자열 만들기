function solution(s) {
    return s.split(' ') // 1. 공백을 기준으로 문자열을 자릅니다.
            .map(word => {
                // 2. 단어가 빈 문자열인 경우(연속된 공백) 그대로 반환합니다.
                if (word === "") return ""; 
                
                // 3. 첫 글자는 대문자로, 나머지는 소문자로 변환하여 합칩니다.
                return word[0].toUpperCase() + word.substring(1).toLowerCase();
            })
            .join(' '); // 4. 다시 공백을 넣어 하나의 문자열로 합칩니다.
}
